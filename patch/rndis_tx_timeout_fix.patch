+/*
+ * Обработчик TX Timeout для RNDIS устройств.
+ * Планирует полный сброс линка через EVENT_LINK_RESET.
+ */
+static void rndis_tx_timeout(struct net_device *net)
+{
+	struct usbnet *dev = netdev_priv(net);
+
+	netdev_warn(net, "rndis: TX timeout, scheduling link reset\n");
+	usbnet_defer_kevent(dev, EVENT_LINK_RESET);
+}
+
+/*
+ * Сброс RNDIS линка при ошибках.
+ * Вызывается из keventd при установленном флаге EVENT_LINK_RESET.
+ */
+static int rndis_link_reset(struct usbnet *dev)
+{
+	struct net_device *net = dev->net;
+	int retval;
+
+	netdev_warn(net, "rndis: starting link reset...\n");
+
+	netif_carrier_off(net);
+
+	usbnet_terminate_urbs(dev);
+
+	netif_device_detach(net);
+	msleep(20);
+	netif_device_attach(net);
+
+	if (dev->driver_info->reset) {
+		retval = dev->driver_info->reset(dev);
+		if (retval < 0)
+			netdev_warn(net,
+				    "rndis: reset failed: %d\n", retval);
+	}
+
+	netif_carrier_on(net);
+	netif_wake_queue(net);
+
+	netdev_warn(net, "rndis: link reset complete\n");
+	return 0;
+}
+
